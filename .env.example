# ============================================================
# SpikeMonitor — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ---- Required ----
TELEGRAM_BOT_TOKEN=7123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100123456789

# ---- Database ----
# SQLite (default). For PostgreSQL: postgresql://user:pass@host/dbname
DB_URL=sqlite:///./data/spike_monitor.db

# ---- Exchange ----
BYBIT_BASE_URL=https://api.bybit.com
EXCHANGE_TIMEOUT=15.0
EXCHANGE_MAX_RETRIES=4

# ---- Spike Detection Thresholds ----
SPIKE_THRESHOLD_PCT=30.0           # minimum spike_pct to qualify
STRONG_SPIKE_THRESHOLD_PCT=50.0    # threshold for watchlist addition
WICK_RATIO_MIN=0.40                # (high-close)/(high-low) minimum
RETRACE_THRESHOLD_PCT=70.0         # % of impulse that must be retraced
STRONG_RETRACE_PCT=80.0

# ---- Scoring / Signal Filters ----
MIN_SCORE_ALERT=35.0               # minimum score to send spike alert
MIN_SCORE_WATCHLIST=45.0           # minimum score to add to watchlist
RV20_MIN=1.5                       # minimum relative volume to flag expansion
RV20_STRONG=3.0

# ---- Volume / Liquidity Filters ----
MIN_AVG_QUOTE_VOLUME_USDT=500000   # minimum 20d avg daily USDT volume
MIN_HISTORY_DAYS=30                # require at least 30 daily candles
MAX_UNIVERSE_SIZE=300              # cap scanned universe for performance

# ---- Consolidation Detection ----
CONSOLIDATION_MIN_BARS=3
CONSOLIDATION_MAX_BARS=20
CONSOLIDATION_MAX_RANGE_PCT=8.0
CONSOLIDATION_CONTRACTION_THRESHOLD=0.85

# ---- Breakdown Detection ----
BREAKDOWN_CONFIRMATION_PCT=0.3     # close must be 0.3%+ below support
BREAKDOWN_VOLUME_MULTIPLIER=1.3    # breakdown volume vs average

# ---- Watchlist / TTL ----
WATCHLIST_TTL_HOURS=168            # 7 days
SIGNAL_COOLDOWN_HOURS=24           # don't re-alert same setup within this window
NOTIFICATION_DEDUP_HOURS=6         # spike candidate dedup window

# ---- Scheduler (cron, UTC) ----
DAILY_SCAN_CRON=0 1 * * *          # 01:00 UTC
SCAN_4H_CRON=0 */4 * * *
SCAN_1H_CRON=5 * * * *
HEALTH_PING_CRON=0 */6 * * *

# ---- Charts ----
CHART_OUTPUT_DIR=./data/charts
CHART_DPI=150

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON=false                     # set true for structured JSON logs

# ---- Universe Filtering ----
# Comma-separated symbols to always skip
BLACKLIST=
# Comma-separated symbols to ONLY scan (overrides all other filters)
WHITELIST=

# ---- Optional Enrichments ----
ENABLE_FUNDING_ENRICHMENT=true
ENABLE_OI_ENRICHMENT=false         # set true when OI available


# ============================================================
# IBC (Impulse → Base → Continuation) Module Configuration
# All keys are prefixed IBC_
# ============================================================

# ---- Phase 1: Impulse Detection ----
IBC_IMPULSE_MIN_PCT=15.0           # Minimum total price move (%) to qualify as impulse
IBC_IMPULSE_MAX_BARS=5             # Maximum consecutive bars forming the impulse
IBC_IMPULSE_RV_MIN=1.5             # Minimum relative volume (impulse avg / 20-bar avg)
IBC_IMPULSE_ATR_MIN=3.0            # Minimum ATR multiple for the impulse move
IBC_IMPULSE_SCAN_CRON=0 */4 * * * # Full-universe scan cadence (default: every 4 hours)

# ---- Phase 2: Level / Base Detection ----
IBC_LEVEL_CLUSTER_PCT=1.0          # ±% corridor for clustering extremes into a level
IBC_LEVEL_MIN_TOUCHES=2            # Minimum extremes required to validate a level
IBC_LEVEL_MAX_AGE_BARS=30          # Maximum bar age for a level to remain valid
IBC_BASE_MAX_RANGE_PCT=10.0        # Maximum consolidation range % for base (wide base penalty above this)
IBC_BASE_VOLUME_DECAY=0.6

# Phase 2 ceiling detection (flat-ceiling clustering)
IBC_CEILING_CLUSTER_TOL_PCT=2.0     # ±% tolerance for grouping highs/lows into one level
IBC_CEILING_MIN_TOUCHES=8            # min bars whose high/low touches the ceiling cluster
IBC_CEILING_MIN_FLAT_RATIO=0.25      # min fraction of base bars touching ceiling (0–1)
IBC_CEILING_MAX_AGE_BARS=120         # max bars to look back for ceiling base detection

# Timeframes to scan for IBC impulses (Bybit interval strings, comma-separated)
IBC_SCAN_TIMEFRAMES=60,15            # 60=1H  15=15M          # Maximum ratio of base avg volume / recent avg volume
IBC_MONITOR_CRON=*/30 * * * *      # Base monitor cadence (default: every 30 minutes)

# ---- Phase 3: Breakout Detection ----
IBC_BREAKOUT_CONFIRM_PCT=0.3       # Close must be ≥ this % beyond level to confirm
IBC_BREAKOUT_VOL_MULT=1.3          # Breakout candle volume must be ≥ avg × this factor
IBC_BREAKOUT_CRON=*/15 * * * *     # Breakout poll cadence (default: every 15 minutes)

# ---- Deduplication / TTL ----
IBC_COOLDOWN_H=24                  # Hours before same setup can trigger another breakout alert
IBC_WATCHLIST_TTL_HOURS=168        # Hours before an IBC entry expires without breakout (7 days)
