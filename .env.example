# ============================================================
# SpikeMonitor — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ---- Required ----
TELEGRAM_BOT_TOKEN=7123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100123456789

# ---- Database ----
# SQLite (default). For PostgreSQL: postgresql://user:pass@host/dbname
DB_URL=sqlite:///./data/spike_monitor.db

# ---- Exchange ----
BYBIT_BASE_URL=https://api.bybit.com
EXCHANGE_TIMEOUT=15.0
EXCHANGE_MAX_RETRIES=4

# ---- Spike Detection Thresholds ----
SPIKE_THRESHOLD_PCT=30.0           # minimum spike_pct to qualify
STRONG_SPIKE_THRESHOLD_PCT=50.0    # threshold for watchlist addition
WICK_RATIO_MIN=0.40                # (high-close)/(high-low) minimum
RETRACE_THRESHOLD_PCT=70.0         # % of impulse that must be retraced
STRONG_RETRACE_PCT=80.0

# ---- Scoring / Signal Filters ----
MIN_SCORE_ALERT=35.0               # minimum score to send spike alert
MIN_SCORE_WATCHLIST=45.0           # minimum score to add to watchlist
RV20_MIN=1.5                       # minimum relative volume to flag expansion
RV20_STRONG=3.0

# ---- Volume / Liquidity Filters ----
MIN_AVG_QUOTE_VOLUME_USDT=500000   # minimum 20d avg daily USDT volume
MIN_HISTORY_DAYS=30                # require at least 30 daily candles
MAX_UNIVERSE_SIZE=300              # cap scanned universe for performance

# ---- Consolidation Detection ----
CONSOLIDATION_MIN_BARS=3
CONSOLIDATION_MAX_BARS=20
CONSOLIDATION_MAX_RANGE_PCT=8.0
CONSOLIDATION_CONTRACTION_THRESHOLD=0.85

# ---- Breakdown Detection ----
BREAKDOWN_CONFIRMATION_PCT=0.3     # close must be 0.3%+ below support
BREAKDOWN_VOLUME_MULTIPLIER=1.3    # breakdown volume vs average

# ---- Watchlist / TTL ----
WATCHLIST_TTL_HOURS=168            # 7 days
SIGNAL_COOLDOWN_HOURS=24           # don't re-alert same setup within this window
NOTIFICATION_DEDUP_HOURS=6         # spike candidate dedup window

# ---- Scheduler (cron, UTC) ----
DAILY_SCAN_CRON=0 1 * * *          # 01:00 UTC
SCAN_4H_CRON=0 */4 * * *
SCAN_1H_CRON=5 * * * *
HEALTH_PING_CRON=0 */6 * * *

# ---- Charts ----
CHART_OUTPUT_DIR=./data/charts
CHART_DPI=150

# ---- Logging ----
LOG_LEVEL=INFO
LOG_JSON=false                     # set true for structured JSON logs

# ---- Universe Filtering ----
# Comma-separated symbols to always skip
BLACKLIST=
# Comma-separated symbols to ONLY scan (overrides all other filters)
WHITELIST=

# ---- Optional Enrichments ----
ENABLE_FUNDING_ENRICHMENT=true
ENABLE_OI_ENRICHMENT=false         # set true when OI available
